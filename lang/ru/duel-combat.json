      "DuelCombat": {
        "Title": "\u0414\u0443\u044d\u043b\u044c - \u0411\u043e\u0435\u0432\u0430\u044f",
        "Launcher": {
          "Title": "\u0417\u0430\u043f\u0443\u0441\u043a \u0431\u043e\u0435\u0432\u043e\u0439 \u0434\u0443\u044d\u043b\u0438",
          "Body": "\u0417\u0430\u0433\u0440\u0443\u0436\u0430\u0435\u0442\u0441\u044f \u043e\u043a\u043d\u043e \u0434\u0443\u044d\u043b\u0438 \u0438\u0437 \u0432\u0441\u0442\u0440\u043e\u0435\u043d\u043d\u043e\u0433\u043e \u043c\u0430\u043a\u0440\u043e\u0441\u0430 \u043c\u043e\u0434\u0443\u043b\u044f...",
          "Error": "\u041d\u0435 \u0443\u0434\u0430\u043b\u043e\u0441\u044c \u043e\u0442\u043a\u0440\u044b\u0442\u044c \u0431\u043e\u0435\u0432\u0443\u044e \u0434\u0443\u044d\u043b\u044c. \u041f\u0440\u043e\u0432\u0435\u0440\u044c\u0442\u0435 \u043a\u043e\u043d\u0441\u043e\u043b\u044c."
        },
        "Rules": {
          "HelpTitle": "\u041f\u0440\u0430\u0432\u0438\u043b\u0430 \u0431\u043e\u0435\u0432\u043e\u0439 \u0434\u0443\u044d\u043b\u0438",
          "HelpHtml": "<div style=\"font-family:'Signika',sans-serif; line-height:1.5; color:#1a1a1a; padding:15px; background:url('ui/parchment.jpg'); border:2px solid #540000;\"><h2 style=\"border-bottom:2px solid #700; color:#700; text-align:center; font-family:'Modesto Condensed', serif;\">\u0411\u041e\u0415\u0412\u0410\u042f \u0414\u0423\u042d\u041b\u042c</h2><p><b>\u0426\u0435\u043b\u044c:</b> \u043d\u0430\u043d\u0435\u0441\u0442\u0438 \u043f\u0440\u043e\u0442\u0438\u0432\u043d\u0438\u043a\u0443 \u0420\u0430\u043d\u044b, \u0440\u0430\u0432\u043d\u044b\u0435 \u0435\u0433\u043e \u043f\u043e\u0440\u043e\u0433\u0443 \u0421\u043c\u0435\u0440\u0442\u0438. \u0411\u0430\u0437\u043e\u0432\u043e \u044d\u0442\u043e 4, \u0447\u0435\u0440\u0442\u0430 <i>\u0416\u0438\u0432\u0443\u0447\u0435\u0441\u0442\u044c</i> \u043f\u043e\u0432\u044b\u0448\u0430\u0435\u0442 \u043f\u043e\u0440\u043e\u0433, \u0430 <i>\u041e\u0431\u0440\u0435\u0447\u0451\u043d</i> \u0441\u043d\u0438\u0436\u0430\u0435\u0442.</p><p><b>\u0420\u0430\u0443\u043d\u0434:</b> \u0443 \u043a\u0430\u0436\u0434\u043e\u0433\u043e 3 \u0441\u043b\u043e\u0442\u0430 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0439, \u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0440\u0430\u0441\u043a\u0440\u044b\u0432\u0430\u044e\u0442\u0441\u044f \u043e\u0434\u043d\u043e\u0432\u0440\u0435\u043c\u0435\u043d\u043d\u043e.</p><h3 style=\"color:#900;\">1. \u0414\u0415\u0419\u0421\u0422\u0412\u0418\u042f</h3><ul><li><b>\u0410\u0442\u0430\u043a\u0430:</b> \u0432\u044b\u0431\u0440\u0430\u043d\u043d\u043e\u0435 \u043e\u0440\u0443\u0436\u0438\u0435 \u043f\u0440\u043e\u0442\u0438\u0432 \u041a\u0411. \u0423\u0441\u043f\u0435\u0445 \u043d\u0430\u043d\u043e\u0441\u0438\u0442 1 \u0420\u0430\u043d\u0443, \u043a\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0443\u0441\u043f\u0435\u0445 2 \u0420\u0430\u043d\u044b.</li><li><b>\u041e\u0431\u043e\u0440\u043e\u043d\u0430:</b> \u0433\u043b\u0443\u0445\u0430\u044f \u0437\u0430\u0449\u0438\u0442\u0430. \u041b\u044e\u0431\u044b\u0435 \u0432\u0440\u0430\u0436\u0434\u0435\u0431\u043d\u044b\u0435 \u043f\u0440\u043e\u0432\u0435\u0440\u043a\u0438 \u043f\u0440\u043e\u0442\u0438\u0432 \u0434\u0443\u044d\u043b\u044f\u043d\u0442\u0430 \u0431\u0440\u043e\u0441\u0430\u044e\u0442\u0441\u044f \u0441 \u043d\u0435\u0443\u0434\u0430\u0447\u0435\u0439: 2d20 \u0438 \u0431\u0435\u0440\u0451\u0442\u0441\u044f \u0445\u0443\u0434\u0448\u0438\u0439 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442.</li><li><b>\u041c\u0430\u043d\u0451\u0432\u0440:</b> \u0410\u0442\u043b\u0435\u0442\u0438\u043a\u0430 \u043f\u0440\u043e\u0442\u0438\u0432 \u0421\u0442\u043e\u0439\u043a\u043e\u0441\u0442\u0438, \u0410\u043a\u0440\u043e\u0431\u0430\u0442\u0438\u043a\u0430 \u043f\u0440\u043e\u0442\u0438\u0432 \u0420\u0435\u0444\u043b\u0435\u043a\u0441\u0430, \u0417\u0430\u043f\u0443\u0433\u0438\u0432\u0430\u043d\u0438\u0435 \u043f\u0440\u043e\u0442\u0438\u0432 \u0412\u043e\u043b\u0438, \u041e\u0431\u043c\u0430\u043d \u043f\u0440\u043e\u0442\u0438\u0432 \u0412\u043e\u0441\u043f\u0440\u0438\u044f\u0442\u0438\u044f. \u0423\u0441\u043f\u0435\u0445 \u0434\u0430\u0451\u0442 \u0446\u0435\u043b\u0438 -2 \u041a\u0411 \u043d\u0430 \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0438\u0439 \u0440\u0430\u0443\u043d\u0434, \u043a\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0443\u0441\u043f\u0435\u0445 \u0435\u0449\u0451 \u0438 -1 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435.</li></ul><h3 style=\"color:#900;\">2. \u0412\u0417\u0410\u0418\u041c\u041e\u0414\u0415\u0419\u0421\u0422\u0412\u0418\u0415 \u0414\u0415\u0419\u0421\u0422\u0412\u0418\u0419</h3><ul><li><b>\u0410\u0442\u0430\u043a\u0430 vs \u041e\u0431\u043e\u0440\u043e\u043d\u0430:</b> \u0430\u0442\u0430\u043a\u0443\u044e\u0449\u0438\u0439 \u043f\u043e\u043b\u0443\u0447\u0430\u0435\u0442 \u043d\u0435\u0443\u0434\u0430\u0447\u0443 \u043d\u0430 \u0431\u0440\u043e\u0441\u043e\u043a.</li><li><b>\u041c\u0430\u043d\u0451\u0432\u0440 vs \u0410\u0442\u0430\u043a\u0430:</b> \u043c\u0430\u043d\u0435\u0432\u0440\u0438\u0440\u0443\u044e\u0449\u0438\u0439 \u043f\u043e\u043b\u0443\u0447\u0430\u0435\u0442 -2 \u043a \u0431\u0440\u043e\u0441\u043a\u0443.</li><li><b>\u041c\u0430\u043d\u0451\u0432\u0440 vs \u041e\u0431\u043e\u0440\u043e\u043d\u0430:</b> \u043e\u0431\u043e\u0440\u043e\u043d\u0430 \u043f\u0440\u043e\u0440\u0432\u0430\u043d\u0430, \u041a\u0421 \u0437\u0430\u0449\u0438\u0442\u043d\u0438\u043a\u0430 \u0441\u043d\u0438\u0436\u0430\u0435\u0442\u0441\u044f \u043d\u0430 2.</li></ul><h3 style=\"color:#900;\">3. \u0428\u041c\u0410</h3><p>\u0428\u0442\u0440\u0430\u0444 \u043c\u043d\u043e\u0436\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0439 \u0430\u0442\u0430\u043a\u0438 \u0441\u0447\u0438\u0442\u0430\u0435\u0442\u0441\u044f \u043e\u0442\u0434\u0435\u043b\u044c\u043d\u043e \u0434\u043b\u044f \u0410\u0442\u0430\u043a\u0438 \u0438 \u0434\u043b\u044f \u043a\u0430\u0436\u0434\u043e\u0433\u043e \u0432\u0438\u0434\u0430 \u041c\u0430\u043d\u0451\u0432\u0440\u0430: 0 / -4 / -8.</p></div>"
        }
      }
    }
  }
}
